# 复制为 .env 后按需修改。docker-compose.yml 与本地 Python 进程共用这份配置。

# ---- MinIO (对象存储，OSS 替身) ----
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=lake

# ---- Lance（样本本体，多模态存储；MVP 默认本地磁盘后端，见组件清单 2.4）----
LANCE_ROOT=./data/lance

# ---- Postgres ----
# dagster 库：Dagster 自身运行时元数据（run/event log/schedule 状态）
# 宿主机上 5432 常被本机已有的 postgres 占用，容器对外映射到 55432，避免冲突
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_HOST_PORT=55432
POSTGRES_USER=edp
POSTGRES_PASSWORD=edp123
POSTGRES_DAGSTER_DB=dagster
# platform 库：业务瞬态状态（upload_session/annotation_batch/alerts/pipeline_step_config...）
POSTGRES_PLATFORM_DB=platform

# ---- Kafka（业务事件账本，仅记录不触发）----
# 宿主机进程（gateway/dagster/引擎）走 PLAINTEXT_HOST 监听器，用 9094；
# 容器内部互连（如未来把某服务也放进 compose）才用 9092
KAFKA_BOOTSTRAP=localhost:9094
KAFKA_TOPIC=edp.events

# ---- Iceberg REST Catalog ----
ICEBERG_REST_URI=http://localhost:8181
ICEBERG_WAREHOUSE=s3://lake/warehouse
ICEBERG_CATALOG_NAME=edp

# ---- 网关 / Dagster ----
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
DAGSTER_HOST=localhost
DAGSTER_PORT=3000

# ---- 其它 ----
LOG_LEVEL=INFO
